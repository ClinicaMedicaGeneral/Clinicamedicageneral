rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ Helpers ═══════════════════════════════════════════════
    function isAuth() {
      return request.auth != null;
    }
    function isDoctor() {
      return isAuth() && request.auth.token.email in [
        'expedientes.clinicamedicacmg@gmail.com',
        'rubenwainwrightba@gmail.com',
        'ventasymercadeocmg@gmail.com',
        // DRM Fun-2: médicos tratantes individuales
        'doctor_rojascmg@gmail.com',
        'doctor_hermescmg@gmail.com',
        'doctor_alvarezcmg@gmail.com'
      ];
    }
    function isAdmin() {
      return isAuth() && request.auth.token.email in [
        'ventasymercadeocmg@gmail.com',
        'rubenwainwrightba@gmail.com'
      ];
    }

    // ═══ /users/{uid} ══════════════════════════════════════════
    // Perfil del usuario (códigos de expediente vinculados/compartidos).
    match /users/{userId} {
      allow read: if (isAuth() && request.auth.uid == userId) || isAdmin();
      allow create, update: if isAuth() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ═══ /expedientes/{codigo} ═════════════════════════════════
    match /expedientes/{codigo} {
      // Cualquier usuario autenticado puede leer un expediente si conoce el código.
      // El código único actúa como control de acceso.
      allow read: if isDoctor() || isAuth();

      // Solo el doctor crea expedientes.
      allow create: if isDoctor();

      // Update:
      //   - Doctor: siempre.
      //   - Paciente sin owner asignado: puede reclamar (set ownerUid).
      //   - Paciente con owner: solo agregarse a sí mismo a compartidoCon.
      allow update: if isDoctor()
        || (
          isAuth()
          && resource.data.ownerUid == null
          && request.resource.data.ownerUid == request.auth.uid
        )
        || (
          isAuth()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['compartidoCon', 'solicitudesAcceso', 'updatedAt'])
        )
        || (
          isAuth()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['solicitudesAcceso', 'updatedAt'])
        );

      allow delete: if isDoctor();
    }

    // ═══ /consultas/{id} ═══════════════════════════════════════
    match /consultas/{consultaId} {
      allow read: if isDoctor()
        || (
          isAuth()
          && exists(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente))
          && (
            get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.ownerUid == request.auth.uid
            || (
              get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon is list
              && request.auth.uid in get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon
            )
          )
        );

      allow create, update, delete: if isDoctor();
    }

    // ═══ /quotations/{id} ══════════════════════════════════════
    // Cotizaciones guardadas: cada usuario lee/escribe solo las suyas.
    // Admin puede leer y borrar todo (para limpieza).
    match /quotations/{quotationId} {
      allow read: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ═══ /d365solicitudes/{id} ═════════════════════════════════
    // Solicitudes del programa Doctor 365:
    //   - Usuario: lee/crea/actualiza solo las suyas.
    //   - Admin: lee y modifica todas.
    match /d365solicitudes/{solId} {
      allow read: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();

      // Subcolección /dependientes/{depId}
      match /dependientes/{depId} {
        allow read: if isAdmin()
          || (isAuth()
              && get(/databases/$(database)/documents/d365solicitudes/$(solId)).data.userId == request.auth.uid);
        allow create: if isAuth()
          && get(/databases/$(database)/documents/d365solicitudes/$(solId)).data.userId == request.auth.uid;
        allow update, delete: if isAdmin()
          || (isAuth()
              && get(/databases/$(database)/documents/d365solicitudes/$(solId)).data.userId == request.auth.uid);
      }
    }

    // ═══ /resultadosPruebas/{id} ═════════════════════════════
    // Resultados de pruebas rápidas:
    //   - Staff (isDoctor): lectura/escritura total.
    //   - Paciente: puede leer las pruebas ligadas a su expediente
    //     (owner o compartido) por codigoPaciente.
    match /resultadosPruebas/{resultadoId} {
      allow read: if isDoctor()
        || (
          isAuth()
          && resource.data.codigoPaciente != null
          && exists(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente))
          && (
            get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.ownerUid == request.auth.uid
            || (
              get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon is list
              && request.auth.uid in get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon
            )
          )
        );
      allow create, update:  if isDoctor();
      allow delete:          if isDoctor();
    }

    // ═══ /examenesLaboratorio/{id} ════════════════════════════
    // Exámenes de laboratorio externos (PDFs):
    //   - Staff (isDoctor): lectura/escritura total.
    //   - Paciente: puede leer los exámenes ligados a su expediente.
    //   - Paciente: puede CREAR (subir) exámenes solo a SU PROPIO expediente
    //     (ownerUid === su uid), siempre con flag subidoPorPaciente=true.
    //   - Paciente: NO puede editar ni borrar (solo staff).
    match /examenesLaboratorio/{examenId} {
      allow read: if isDoctor()
        || (
          isAuth()
          && resource.data.codigoPaciente != null
          && exists(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente))
          && (
            get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.ownerUid == request.auth.uid
            || (
              get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon is list
              && request.auth.uid in get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon
            )
          )
        );
      allow create: if isDoctor()
        || (
          isAuth()
          && request.resource.data.codigoPaciente != null
          && request.resource.data.subidoPorPaciente == true
          && exists(/databases/$(database)/documents/expedientes/$(request.resource.data.codigoPaciente))
          && get(/databases/$(database)/documents/expedientes/$(request.resource.data.codigoPaciente)).data.ownerUid == request.auth.uid
        );
      allow update: if isDoctor();
      allow delete: if isDoctor();
    }

    // ═══ Bloqueo por defecto ═══════════════════════════════════
    // Cualquier otra colección queda bloqueada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
