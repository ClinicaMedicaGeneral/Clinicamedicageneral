rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isDoctor() {
      return isAuth() && request.auth.token.email in [
        'expedientes.clinicamedicacmg@gmail.com',
        'rubenwainwrightba@gmail.com',
        'ventasymercadeocmg@gmail.com'
      ];
    }

    // ─── /users/{uid} ─────────────────────────────────────────
    // Cada usuario solo puede leer/escribir su propio perfil.
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create, update: if isAuth() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ─── /expedientes/{codigo} ────────────────────────────────
    // - Doctor: acceso total.
    // - Paciente owner: lee y puede agregarse a "compartidoCon" si otro lo invita.
    // - Paciente sin owner: puede reclamar (setear ownerUid a su uid).
    match /expedientes/{codigo} {

      allow read: if isDoctor()
        || (isAuth() && resource.data.ownerUid == request.auth.uid)
        || (isAuth() && resource.data.compartidoCon is list
            && request.auth.uid in resource.data.compartidoCon);

      // Solo el doctor crea expedientes.
      allow create: if isDoctor();

      // Update: doctor siempre. Paciente solo si:
      //   a) Reclama ownership (ownerUid era null y ahora es su uid)
      //   b) Se agrega a sí mismo a compartidoCon (sin modificar otros campos sensibles)
      allow update: if isDoctor()
        || (
          isAuth()
          && resource.data.ownerUid == null
          && request.resource.data.ownerUid == request.auth.uid
        )
        || (
          isAuth()
          && resource.data.ownerUid != null
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['compartidoCon', 'updatedAt'])
        );

      allow delete: if isDoctor();
    }

    // ─── /consultas/{id} ──────────────────────────────────────
    // - Doctor: acceso total.
    // - Paciente: lee si es owner del expediente referenciado o
    //   si el expediente está en su compartidoCon.
    match /consultas/{consultaId} {

      allow read: if isDoctor()
        || (
          isAuth()
          && exists(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente))
          && (
            get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.ownerUid == request.auth.uid
            || (
              get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon is list
              && request.auth.uid in get(/databases/$(database)/documents/expedientes/$(resource.data.codigoPaciente)).data.compartidoCon
            )
          )
        );

      allow create, update, delete: if isDoctor();
    }

    // ─── /quotations/{id} ─────────────────────────────────────
    // Comportamiento existente: el usuario lee/escribe solo sus cotizaciones.
    match /quotations/{quotationId} {
      allow read, write: if isAuth()
        && (
          (resource != null && request.auth.uid == resource.data.userId)
          || (request.resource != null && request.auth.uid == request.resource.data.userId)
        );
    }

    // ─── /doctor365/{...} y otras colecciones existentes ──────
    // Permite la lectura para usuarios autenticados; ajusta según necesites.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
