rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }
    function isDoctor() {
      return isAuth() && request.auth.token.email in [
        'expedientes.clinicamedicacmg@gmail.com',
        'rubenwainwrightba@gmail.com',
        'ventasymercadeocmg@gmail.com',
        // DRM Fun-2: médicos tratantes individuales
        'doctor_rojascmg@gmail.com',
        'doctor_hermescmg@gmail.com',
        'doctor_alvarezcmg@gmail.com',
        // Admin operativo
        'skarleth.admoncmg@gmail.com'
      ];
    }

    // ─── Archivos de expedientes (PDFs de consulta, Word del expediente) ──
    // Estructura: /expedientes/{codigoPaciente}/...
    //   - Lectura: cualquier usuario autenticado (la URL es secreta y se
    //     guarda en Firestore, que está protegido por las rules de Firestore).
    //   - Escritura: solo doctores autorizados.
    match /expedientes/{codigo}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isDoctor();
    }

    // ─── Exámenes de laboratorio (PDFs externos) ──
    // Estructura: /examenes-laboratorio/{codigoPaciente|paciente-{uid}|sin-expediente}/...
    //   - Lectura: cualquier usuario autenticado.
    //   - Escritura: doctores (a cualquier carpeta) y pacientes
    //     (cualquier autenticado puede subir; control real vía Firestore
    //     que solo permite vincular a su propio expediente).
    match /examenes-laboratorio/{folder}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ─── Cualquier otra ruta ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
