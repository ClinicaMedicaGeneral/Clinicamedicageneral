rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }
    function isDoctor() {
      return isAuth() && request.auth.token.email in [
        'expedientes.clinicamedicacmg@gmail.com',
        'rubenwainwrightba@gmail.com',
        'ventasymercadeocmg@gmail.com'
      ];
    }

    // ─── Archivos de expedientes (PDFs de consulta, Word del expediente) ──
    // Estructura: /expedientes/{codigoPaciente}/...
    //   - Lectura: cualquier usuario autenticado (la URL es secreta y se
    //     guarda en Firestore, que está protegido por las rules de Firestore).
    //   - Escritura: solo doctores autorizados.
    match /expedientes/{codigo}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isDoctor();
    }

    // ─── Cualquier otra ruta ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
